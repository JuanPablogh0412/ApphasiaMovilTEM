rules_version = '2';

// Reglas de Firebase Storage para RehabilitIA — modo desarrollo.
// Permite leer y escribir a cualquier usuario autenticado.
// Sprint 3: restringir por pacienteId cuando se implemente el rol de terapeuta.

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
