rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════
    //  Funciones auxiliares
    // ══════════════════════════════════════════════════════════
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }
    function isTerapeuta() {
      return isSignedIn() && request.auth.token.role == 'terapeuta';
    }
    function isCreador() {
      return isSignedIn() && request.auth.token.role == 'creador';
    }
    function isStaff() {
      return isAdmin() || isTerapeuta();
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ══════════════════════════════════════════════════════════
    //  pacientes
    //  - Staff: lectura, creación, actualización, eliminación
    //  - Paciente: crea su perfil al registrarse, lee y actualiza
    // ══════════════════════════════════════════════════════════
    match /pacientes/{pacienteId} {
      allow read:   if isStaff() || isOwner(pacienteId);
      allow create: if isStaff() || isOwner(pacienteId);
      allow update: if isStaff() || isOwner(pacienteId);
      allow delete: if isAdmin();

      // ejercicios asignados (terapeuta asigna, paciente lee)
      match /ejercicios_asignados/{asignacionId} {
        allow read:  if isStaff() || isOwner(pacienteId);
        allow write: if isStaff();
      }

      // calibración vocal (paciente sube desde móvil)
      match /calibration/{calId} {
        allow read:  if isStaff() || isOwner(pacienteId);
        allow write: if isStaff() || isOwner(pacienteId);
      }
    }

    // ══════════════════════════════════════════════════════════
    //  ejercicios  (general — compartida por TEM, SR, VNEST)
    //  Cloud Functions (admin SDK) manejan escrituras de paciente.
    //  Staff y creadores escriben desde la web.
    // ══════════════════════════════════════════════════════════
    match /ejercicios/{docId} {
      allow read:  if isSignedIn();
      allow write: if isStaff() || isCreador();
    }

    // ══════════════════════════════════════════════════════════
    //  ejercicios_TEM
    //  Cloud Functions (admin SDK) manejan escrituras de paciente.
    // ══════════════════════════════════════════════════════════
    match /ejercicios_TEM/{docId} {
      allow read:  if isSignedIn();
      allow write: if isStaff();
    }

    // ══════════════════════════════════════════════════════════
    //  ejercicios_VNEST
    // ══════════════════════════════════════════════════════════
    match /ejercicios_VNEST/{docId} {
      allow read:  if isSignedIn();
      allow write: if isStaff() || isCreador();
    }

    // ══════════════════════════════════════════════════════════
    //  ejercicios_SR
    // ══════════════════════════════════════════════════════════
    match /ejercicios_SR/{docId} {
      allow read:  if isSignedIn();
      allow write: if isStaff() || isCreador();
    }

    // ══════════════════════════════════════════════════════════
    //  stimuli_TEM  (catálogo de estímulos)
    // ══════════════════════════════════════════════════════════
    match /stimuli_TEM/{docId} {
      allow read:  if isSignedIn();
      allow write: if isStaff() || isCreador();
    }

    // ══════════════════════════════════════════════════════════
    //  sesiones_TEM  +  subcollection attempts
    //  - Staff: acceso total
    //  - Paciente: crea/actualiza solo SUS sesiones e intentos
    // ══════════════════════════════════════════════════════════
    match /sesiones_TEM/{sessionId} {
      allow read:   if isSignedIn();
      allow create: if isStaff()
                    || (isSignedIn() && request.resource.data.pacienteId == request.auth.uid);
      allow update: if isStaff()
                    || (isSignedIn() && resource.data.pacienteId == request.auth.uid);
      allow delete: if isStaff();

      match /attempts/{attemptId} {
        allow read:   if isSignedIn();
        allow create: if isStaff()
                      || (isSignedIn() && request.resource.data.pacienteId == request.auth.uid);
        allow update: if isStaff()
                      || (isSignedIn() && resource.data.pacienteId == request.auth.uid);
        allow delete: if isStaff();
      }
    }

    // ══════════════════════════════════════════════════════════
    //  analysis_results_TEM
    //  Backend Python usa Admin SDK (bypass). Solo staff desde web.
    // ══════════════════════════════════════════════════════════
    match /analysis_results_TEM/{docId} {
      allow read:  if isSignedIn();
      allow write: if isStaff();
    }

    // ══════════════════════════════════════════════════════════
    //  asignaciones_TEM  (terapeuta asigna estímulos a paciente)
    //  Paciente solo lee para cargar sus asignaciones activas.
    // ══════════════════════════════════════════════════════════
    match /asignaciones_TEM/{docId} {
      allow read:  if isSignedIn();
      allow write: if isStaff();
    }

    // ══════════════════════════════════════════════════════════
    //  terapeutas
    //  Cloud Function aprobarTerapeuta crea el doc (admin SDK).
    //  Admin gestiona; terapeuta actualiza su propio perfil.
    // ══════════════════════════════════════════════════════════
    match /terapeutas/{terapeutaId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(terapeutaId);
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    //  creadores
    //  Cloud Function registrarCreador crea el doc (admin SDK).
    // ══════════════════════════════════════════════════════════
    match /creadores/{creadorId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    //  solicitudes  (registro terapeuta → admin aprueba)
    //  Cualquier usuario autenticado puede solicitar ser terapeuta.
    // ══════════════════════════════════════════════════════════
    match /solicitudes/{solicitudId} {
      allow read:   if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    //  contextos  (catálogo de categorías)
    // ══════════════════════════════════════════════════════════
    match /contextos/{contextoId} {
      allow read:  if isSignedIn();
      allow write: if isStaff() || isCreador();
    }

    // ══════════════════════════════════════════════════════════
    //  pending_recordings  (puente QR web ↔ móvil para grabación)
    // ══════════════════════════════════════════════════════════
    match /pending_recordings/{recordingId} {
      allow read:  if isSignedIn();
      allow write: if isStaff() || isCreador();
    }

  }
}
